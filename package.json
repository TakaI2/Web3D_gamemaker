{
  "name": "web3d-gamemaker",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "node node_modules/vite/bin/vite.js build",
    "build:fps": "node node_modules/vite/bin/vite.js build --config vite.config.fps.ts",
    "build:cloth": "node scripts/build-cloth.mjs",
    "build:fps-cloth": "node scripts/build-fps-cloth.mjs",
    "build:fps-cloth-mobile": "node scripts/build-fps-cloth-mobile.mjs",
    "build:fps-cloth-vrm": "node scripts/build-fps-cloth-vrm.mjs",
    "build:fps-cloth-vrm-mobile": "node scripts/build-fps-cloth-vrm-mobile.mjs",
    "build:swing-catch": "node scripts/build-swing-catch.mjs",
    "build:swing-catch-mobile": "node scripts/build-swing-catch-mobile.mjs",
    "build:character-editor": "node scripts/build-character-editor.mjs",
    "build:model-editor": "node scripts/build-model-editor.mjs",
    "build:stage-editor": "node scripts/build-stage-editor.mjs",
    "build:plateau-fly": "node scripts/build-plateau-fly.mjs",
    "build:hub": "node scripts/build-hub.mjs",
    "preview": "node node_modules/vite/bin/vite.js preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "check": "svelte-check --tsconfig ./tsconfig.json",
    "build:cityfly": "node scripts/build-plateau-fly.mjs"
  },
  "dependencies": {
    "@pixiv/three-vrm": "^3.4.0",
    "@pixiv/three-vrm-animation": "^3.4.0",
    "three": "^0.170.0",
    "three-mesh-ui": "^6.5.4"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.0",
    "@sveltejs/vite-plugin-svelte": "^3.0.0",
    "@tsconfig/svelte": "^5.0.0",
    "@types/three": "^0.170.0",
    "@vitejs/plugin-basic-ssl": "^1.1.0",
    "@vitest/coverage-v8": "^2.0.0",
    "jsdom": "^25.0.0",
    "svelte": "^4.2.0",
    "svelte-check": "^4.0.0",
    "typescript": "^5.7.0",
    "vite": "^5.4.0",
    "vitest": "^2.0.0"
  }
}
